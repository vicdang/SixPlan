# ============================================
# SEAT MANAGEMENT SYSTEM — Environment Template
# ============================================

# --- Database (PostgreSQL) ---
POSTGRES_DB=seat_mgmt
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme_strong_password_here
DATABASE_URL=postgresql+asyncpg://admin:changeme_strong_password_here@db:5432/seat_mgmt

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- JWT Auth ---
JWT_SECRET_KEY=replace_with_random_48_char_string_minimum
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Application ---
ENVIRONMENT=development
APP_NAME=Seat Management System
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80,http://localhost

# --- Frontend ---
VITE_API_URL=http://localhost:8000/api/v1
VITE_APP_NAME=SEATMAP

# --- Admin Bootstrap ---
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=ChangeMe@2026
INITIAL_ADMIN_EMAIL=admin@company.local

# --- Future integrations (Phase 3) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@company.local
SMTP_FROM_NAME=Seat Management
TEAMS_WEBHOOK_URL=

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
